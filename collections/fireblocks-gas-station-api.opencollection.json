{
  "opencollection": "1.0.0",
  "info": {
    "name": "Fireblocks Gas Station API",
    "version": "1.8.0"
  },
  "items": [
    {
      "info": {
        "name": "Gas Station",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get gas station settings",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.fireblocks.io/v1/gas_station"
          },
          "docs": "Returns gas station settings and ETH balance.\n</br>Endpoint Permission: Admin, Non-Signing Admin, Signer, Approver, Editor."
        },
        {
          "info": {
            "name": "Get gas station settings by asset",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.fireblocks.io/v1/gas_station/:assetId",
            "params": [
              {
                "name": "assetId",
                "value": "",
                "type": "path",
                "description": "The ID of the asset"
              }
            ]
          },
          "docs": "Returns gas station settings and balances for a requested asset.\n</br>Endpoint Permission: Admin, Non-Signing Admin, Signer, Approver, Editor."
        },
        {
          "info": {
            "name": "Edit gas station settings",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.fireblocks.io/v1/gas_station/configuration",
            "headers": [
              {
                "name": "Idempotency-Key",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Configures gas station settings for ETH.\nLearn more about the Fireblocks Gas Station in the following [guide](https://developers.fireblocks.com/docs/work-with-gas-station).\n</br>Endpoint Permission: Admin, Non-Signing Admin, Signer, Approver, Editor."
        },
        {
          "info": {
            "name": "Edit gas station settings for an asset",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.fireblocks.io/v1/gas_station/configuration/:assetId",
            "headers": [
              {
                "name": "Idempotency-Key",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "assetId",
                "value": "",
                "type": "path",
                "description": "The ID of the asset"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Configures gas station settings for a requested asset.\nLearn more about the Fireblocks Gas Station in the following [guide](https://developers.fireblocks.com/docs/work-with-gas-station).\n</br>Endpoint Permission: Admin, Non-Signing Admin, Signer, Approver, Editor."
        }
      ]
    }
  ],
  "bundled": true
}