            "headers": [
              {
                "name": "Idempotency-Key",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "id",
                "value": "ETH",
                "type": "path",
                "description": "The ID or legacyId of the asset"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update the user’s metadata for an asset.\n\n**Endpoint Permissions:** Owner, Admin, Non-Signing Admin, NCW Admin, Signer, Editor."
        }
      ]
    }
  ],
  "bundled": true
}